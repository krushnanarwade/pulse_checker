# Staging Environment Configuration
ENVIRONMENT=staging
DEBUG=False

# Security
SECRET_KEY=${STAGING_SECRET_KEY}

# Database (use PostgreSQL for staging)
DATABASE_URL=postgresql://${STAGING_DB_USER}:${STAGING_DB_PASSWORD}@${STAGING_DB_HOST}:5432/${STAGING_DB_NAME}

# CORS
CORS_ORIGINS=["https://staging.yourdomain.com"]

# Scheduler
SCHEDULER_ENABLED=True
CHECK_INTERVAL_MINUTES=15

# Alerts
SLACK_WEBHOOK_URL=${STAGING_SLACK_WEBHOOK}
DISCORD_WEBHOOK_URL=${STAGING_DISCORD_WEBHOOK}
